# ---------------------------------------------------------------------------
# Virtual Wardrobe — environment variables
# Copy this file to `.env` and fill in the keys you have. Every key is optional:
# with none set, the app runs in DEMO MODE (localStorage + seeded data, no AI).
# ---------------------------------------------------------------------------

# Gemini (free) — powers photo auto-tagging, the AI stylist, and gap analysis.
# Get a free key at https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=
# Optional: override the model (defaults to gemini-2.5-flash).
# VITE_GEMINI_MODEL=gemini-2.5-flash

# Supabase (free tier) — cloud sync + auth. Leave blank to stay in demo mode.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# OpenWeather (free tier) — weather-aware outfit suggestions.
# Get a key at https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=

# Replicate (optional, PAID) — photorealistic AI try-on. Left out of the free
# stack; the app defaults to free flat-lay collages instead.
# VITE_REPLICATE_API_KEY=
